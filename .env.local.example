# ── Supabase ──────────────────────────────────────────────────────
# Get these at: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Resend (email notifications) ──────────────────────────────────
# Get at: https://resend.com → API Keys
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── Stripe (subscriptions) ────────────────────────────────────────
# Get at: https://stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=your_stripe_price_id

# ── Redis (Rate Limiting - Optional) ──────────────────────────────
# Get at: https://console.upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ── Sentry (Error Monitoring - Optional) ──────────────────────────
# Get at: https://sentry.io → Projects → Create Project
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_public_dsn

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000