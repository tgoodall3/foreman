diff --git a/components/worker/WorkerTabBar.tsx b/components/worker/WorkerTabBar.tsx
new file mode 100644
index 0000000..0f8430d
--- /dev/null
+++ b/components/worker/WorkerTabBar.tsx
@@ -0,0 +1,39 @@
+"use client";
+
+import Link from "next/link";
+import { usePathname } from "next/navigation";
+import { useLanguage } from "@/lib/i18n";
+
+const Icn = ({ d }: { d: string | string[] }) => (
+  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.7" strokeLinecap="round" strokeLinejoin="round" aria-hidden="true">
+    {Array.isArray(d) ? d.map((p, i) => <path key={i} d={p} />) : <path d={d} />}
+  </svg>
+);
+
+export default function WorkerTabBar() {
+  const pathname = usePathname();
+  const { t } = useLanguage();
+
+  const isOn = (href: string) => {
+    if (href === "/worker") return pathname === "/worker";
+    return pathname === href || pathname.startsWith(href + "/");
+  };
+
+  const items: { href: string; label: string; icon: React.ReactNode }[] = [
+    { href: "/worker",            label: t("nav.myJobs"),     icon: <Icn d={["M4 7h16v13H4z","M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"]} /> },
+    { href: "/worker/timesheets", label: t("nav.timesheets"), icon: <Icn d={["M12 7v5l3 2","M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"]} /> },
+    { href: "/worker/completed",  label: "Done",              icon: <Icn d="m4 12 5 5L20 6" /> },
+    { href: "/worker/settings",   label: t("nav.settings"),   icon: <Icn d={["M12 9.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z","M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V22a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H2a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V2a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.09a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.09a1.65 1.65 0 0 0 1.51 1H22a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z"]} /> },
+  ];
+
+  return (
+    <nav className="tabbar fixed bottom-0 left-0 right-0 z-10" aria-label="Worker navigation">
+      {items.map((it) => (
+        <Link key={it.href} href={it.href} className={"ti" + (isOn(it.href) ? " is-active" : "")}>
+          {it.icon}
+          <span>{it.label}</span>
+        </Link>
+      ))}
+    </nav>
+  );
+}
