+  font-weight: 600;
+  display: inline-flex; align-items: center; justify-content: center;
+  border: 1px solid var(--line);
+  letter-spacing: 0;
+  font-family: var(--mono);
+}
+.avatar--lg     { width: 32px; height: 32px; font-size: 12px; border-radius: 8px; }
+.avatar--orange { background: var(--orange-soft); color: var(--orange-ink); border-color: #F4D9A8; }
+.avatar--blue   { background: var(--blue-soft); color: #1A4FA0; border-color: #CCDBF1; }
+.avatar--green  { background: var(--green-soft); color: #135E3F; border-color: #CFE5D9; }
+
+/* ---- Divider ---- */
+.hr { height: 1px; background: var(--line); border: 0; margin: 0; }
+
+/* ---- Tables (v1) ---- */
+.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
+.tbl th {
+  text-align: left;
+  font-family: var(--mono);
+  font-size: 10.5px;
+  font-weight: 500;
+  letter-spacing: 0.14em;
+  text-transform: uppercase;
+  color: var(--muted);
+  padding: 10px 16px;
+  border-bottom: 1px solid var(--line);
+  background: #FFFFFF;
+}
+.tbl td {
+  padding: 12px 16px;
+  border-bottom: 1px solid var(--line);
+  vertical-align: middle;
+}
+.tbl tr:last-child td { border-bottom: 0; }
+.tbl tr:hover td { background: var(--paper); }
+
+/* ---- Owner shell ---- */
+.shell { display: flex; min-height: 100%; background: var(--paper); }
+.shell .sidebar {
+  width: 220px; flex: none;
+  background: var(--nav-bg);
+  color: var(--nav-text);
+  display: flex; flex-direction: column;
+  border-right: 1px solid var(--nav-line);
+}
+.sidebar .brand {
+  display: flex; align-items: center; gap: 9px;
+  padding: 16px 14px 14px;
+  border-bottom: 1px solid var(--nav-line);
+}
+.sidebar .brand-mark {
+  width: 24px; height: 24px; border-radius: 6px;
+  background: var(--orange);
+  display: grid; place-items: center;
+  overflow: hidden;
+  flex: none;
+}
+.sidebar .brand-mark img { width: 100%; height: 100%; object-fit: contain; }
+.sidebar .brand-name {
+  font-size: 14px; font-weight: 600; color: var(--nav-text-hi);
+  letter-spacing: 0.04em;
+}
+.sidebar .brand-org { font-size: 11px; color: var(--nav-text-lo); }
+.sidebar nav { flex: 1; padding: 10px 8px; overflow-y: auto; }
+.sidebar .nav-group { margin-top: 14px; }
+.sidebar .nav-group:first-child { margin-top: 4px; }
+.sidebar .nav-label {
+  font-family: var(--mono);
+  font-size: 10px;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--nav-text-lo);
+  padding: 6px 10px;
+}
+.sidebar a.nav-item,
+.sidebar button.nav-item {
+  display: flex; align-items: center; gap: 9px;
+  padding: 7px 10px;
+  border-radius: 6px;
+  color: var(--nav-text);
+  font-size: 13px;
+  font-weight: 450;
+  text-decoration: none;
+  position: relative;
+  background: transparent;
+  border: 0;
+  width: 100%;
+  cursor: pointer;
+  min-height: 32px;
+  font-family: inherit;
+}
+.sidebar a.nav-item:hover,
+.sidebar button.nav-item:hover { background: var(--nav-bg-2); color: var(--nav-text-hi); }
+.sidebar a.nav-item.active,
+.sidebar button.nav-item.active {
+  background: var(--nav-bg-2);
+  color: var(--nav-text-hi);
+}
+.sidebar a.nav-item.active::before,
+.sidebar button.nav-item.active::before {
+  content: "";
+  position: absolute; left: -8px; top: 7px; bottom: 7px;
+  width: 2px; border-radius: 2px; background: var(--orange);
+}
+.sidebar .nav-item .icn { width: 16px; height: 16px; opacity: .8; flex: none; }
+.sidebar .nav-item .badge {
+  margin-left: auto;
+  font-family: var(--mono); font-size: 10.5px;
+  background: var(--nav-bg-2); color: var(--nav-text-hi);
+  padding: 1px 6px; border-radius: 4px;
+  border: 1px solid var(--nav-line);
+}
+.sidebar .me {
+  display: flex; align-items: center; gap: 10px;
+  padding: 12px 14px;
+  border-top: 1px solid var(--nav-line);
+}
+.sidebar .me .av {
+  width: 28px; height: 28px; border-radius: 7px;
+  background: #2D2A22; color: var(--nav-text-hi);
+  font-family: var(--mono); font-size: 12px; font-weight: 600;
+  display: grid; place-items: center;
+  flex: none;
+}
+.sidebar .me .name { font-size: 12.5px; color: var(--nav-text-hi); }
+.sidebar .me .role { font-size: 11px; color: var(--nav-text-lo); }
+
+.shell .content { flex: 1; min-width: 0; display: flex; flex-direction: column; }
+
+.topbar {
+  display: flex; align-items: center; justify-content: space-between;
+  padding: 14px 24px;
+  border-bottom: 1px solid var(--line);
+  background: var(--paper);
+  gap: 12px;
+}
+.topbar .crumb {
+  display: flex; align-items: center; gap: 8px;
+  font-size: 13px; color: var(--muted);
+  min-width: 0;
+}
+.topbar .crumb b { color: var(--ink); font-weight: 500; }
+.topbar .actions { display: flex; gap: 8px; align-items: center; }
+
+.page { padding: 24px; flex: 1; min-width: 0; }
+@media (max-width: 640px) {
+  .page { padding: 16px; }
+  .topbar { padding: 12px 16px; }
+}
+
+/* Page header */
+.page-h {
+  display: flex; align-items: flex-end; justify-content: space-between; gap: 24px;
+  margin-bottom: 20px;
+  flex-wrap: wrap;
+}
+.page-h h1 { font-size: 24px; font-weight: 500; margin: 0; letter-spacing: -0.02em; }
+.page-h .sub { color: var(--muted); font-size: 13px; margin-top: 4px; }
+
+/* Stat grid */
+.stat-grid {
+  display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
+  border: 1px solid var(--line); border-radius: var(--r-lg);
+  background: #FFFFFF; overflow: hidden;
+}
+@media (max-width: 768px) {
+  .stat-grid { grid-template-columns: repeat(2, 1fr); }
+  .stat-cell:nth-child(2) { border-right: 0; }
+  .stat-cell:nth-child(1), .stat-cell:nth-child(2) { border-bottom: 1px solid var(--line); }
+}
+.stat-cell { padding: 14px 18px; border-right: 1px solid var(--line); }
+.stat-cell:last-child { border-right: 0; }
+.stat-cell .label { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.stat-cell .value { font-size: 28px; font-weight: 500; letter-spacing: -0.02em; margin-top: 6px; font-feature-settings: "tnum"; }
+.stat-cell .meta { font-size: 12px; color: var(--muted); margin-top: 4px; }
+.stat-cell .meta .up { color: var(--green); }
+.stat-cell .meta .dn { color: var(--red); }
+
+/* Two-column layout */
+.grid-2 { display: grid; grid-template-columns: 1.55fr 1fr; gap: 16px; }
+.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
+@media (max-width: 980px) {
+  .grid-2 { grid-template-columns: 1fr; }
+  .grid-3 { grid-template-columns: 1fr; }
+}
+
+/* Job row */
+.job-row {
+  display: grid;
+  grid-template-columns: 64px 1fr auto auto;
+  align-items: center;
+  gap: 14px;
+  padding: 12px 18px;
+  border-bottom: 1px solid var(--line);
+}
+.job-row:last-child { border-bottom: 0; }
+.job-row:hover { background: var(--paper); }
+.job-row .time { font-family: var(--mono); font-size: 12.5px; color: var(--ink-2); }
+.job-row .time .ampm { color: var(--muted); font-size: 10.5px; margin-left: 1px; }
+.job-row .title { font-size: 13.5px; font-weight: 500; }
+.job-row .meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
+.job-row .who  { display: flex; }
+.job-row .who .avatar + .avatar { margin-left: -6px; }
+
+/* Quick action */
+.qa-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 14px; }
+.qa {
+  display: flex; align-items: center; gap: 10px;
+  padding: 11px 12px;
+  border: 1px solid var(--line);
+  border-radius: var(--r);
+  background: #FFFFFF;
+  font-size: 13px;
+  cursor: pointer;
+  color: var(--ink);
+  text-decoration: none;
+}
+.qa:hover { border-color: var(--line-strong); }
+.qa .ic {
+  width: 26px; height: 26px;
+  background: var(--surface-2);
+  border-radius: 6px;
+  display: grid; place-items: center;
+  color: var(--ink-2);
+  flex: none;
+}
+.qa--p .ic { background: var(--orange-soft); color: var(--orange-ink); }
+.qa kbd {
+  margin-left: auto;
+  font-family: var(--mono);
+  font-size: 10.5px;
+  color: var(--muted);
+  background: var(--surface-2);
+  border: 1px solid var(--line);
+  padding: 1px 5px;
+  border-radius: 4px;
+}
+
+/* Activity feed */
+.feed { padding: 4px 0; }
+.feed-item {
+  display: grid; grid-template-columns: 18px 1fr auto;
+  gap: 12px; padding: 10px 18px;
+  align-items: flex-start;
+}
+.feed-item .stem {
+  width: 6px; height: 6px; border-radius: 50%;
+  background: var(--muted-2); margin-top: 6px;
+  margin-left: 6px;
+}
+.feed-item.is-orange .stem { background: var(--orange); }
+.feed-item.is-green  .stem { background: var(--green); }
+.feed-item.is-red    .stem { background: var(--red); }
+.feed-item .body { font-size: 13px; color: var(--ink-2); }
+.feed-item .body b { font-weight: 500; color: var(--ink); }
+.feed-item .meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
+.feed-item .when { font-family: var(--mono); font-size: 11px; color: var(--muted); white-space: nowrap; }
+
+/* Schedule (week) */
+.sched {
+  display: grid;
+  grid-template-columns: 90px repeat(7, 1fr);
+  background: #FFFFFF;
+  font-size: 12px;
+  border: 1px solid var(--line);
+  border-radius: var(--r-lg);
+  overflow: hidden;
+}
+.sched .h {
+  border-bottom: 1px solid var(--line);
+  padding: 10px 10px;
+  background: #FFFFFF;
+}
+.sched .h .dow { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.sched .h .dom { font-size: 18px; font-weight: 500; letter-spacing: -0.02em; margin-top: 2px; font-feature-settings: "tnum"; }
+.sched .h.today .dom { color: var(--orange-ink); }
+.sched .h.today { background: var(--orange-soft); }
+.sched .who-h, .sched .who {
+  border-right: 1px solid var(--line);
+  padding: 10px 12px;
+  background: var(--surface-2);
+}
+.sched .who-h { background: #FFFFFF; border-bottom: 1px solid var(--line); }
+.sched .who {
+  border-top: 1px solid var(--line);
+  display: flex; align-items: center; gap: 9px;
+  font-size: 12.5px;
+}
+.sched .who small { display: block; color: var(--muted); font-size: 11px; font-family: var(--mono); }
+.sched .cell {
+  border-right: 1px solid var(--line);
+  border-top: 1px solid var(--line);
+  padding: 6px;
+  min-height: 70px;
+  position: relative;
+  background: #FFFFFF;
+}
+.sched .cell.today { background: #FDFCF7; }
+.sched .ev {
+  border-radius: 6px;
+  padding: 6px 8px;
+  margin-bottom: 4px;
+  font-size: 11.5px;
+  line-height: 1.25;
+  border: 1px solid var(--line-2);
+  background: var(--surface-2);
+  cursor: pointer;
+}
+.sched .ev b { font-weight: 500; display: block; color: var(--ink); }
+.sched .ev .t { font-family: var(--mono); color: var(--muted); font-size: 10.5px; }
+.sched .ev--orange { background: var(--orange-soft); border-color: #F4D9A8; }
+.sched .ev--orange b { color: var(--orange-ink); }
+.sched .ev--blue   { background: var(--blue-soft); border-color: #CCDBF1; }
+.sched .ev--blue b { color: #1A4FA0; }
+.sched .ev--green  { background: var(--green-soft); border-color: #CFE5D9; }
+.sched .ev--green b { color: #135E3F; }
+.sched .ev--ghost  { background: transparent; border-style: dashed; color: var(--muted); }
+.sched .ev--ghost b { color: var(--muted); font-weight: 500; }
+
+/* Invoice / portal docs */
+.doc {
+  background: #FFFFFF;
+  border: 1px solid var(--line);
+  border-radius: var(--r-lg);
+  padding: 28px 32px;
+}
+.doc h2 { margin: 0; font-size: 22px; font-weight: 500; letter-spacing: -0.02em; }
+.doc .doc-h { display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--line); flex-wrap: wrap; }
+.doc .doc-num { font-family: var(--mono); font-size: 12px; color: var(--muted); }
+.doc .doc-meta { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 18px 0; border-bottom: 1px solid var(--line); }
+@media (max-width: 640px) {
+  .doc { padding: 20px; }
+  .doc .doc-meta { grid-template-columns: repeat(2, 1fr); }
+}
+.doc .doc-meta div .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.doc .doc-meta div .v { font-size: 13.5px; color: var(--ink); margin-top: 4px; }
+.doc table.lines { width: 100%; border-collapse: collapse; margin-top: 8px; }
+.doc table.lines th, .doc table.lines td { padding: 12px 0; font-size: 13px; }
+.doc table.lines th { text-align: left; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); font-weight: 500; border-bottom: 1px solid var(--line); }
+.doc table.lines td { border-bottom: 1px solid var(--line); }
+.doc table.lines td:last-child, .doc table.lines th:last-child { text-align: right; font-variant-numeric: tabular-nums; }
+.doc table.lines td.qty { color: var(--muted); font-variant-numeric: tabular-nums; }
+.doc .totals { display: grid; gap: 6px; margin-top: 16px; margin-left: auto; max-width: 320px; }
+.doc .totals .row { display: flex; justify-content: space-between; font-size: 13px; color: var(--muted); }
+.doc .totals .row.grand { color: var(--ink); font-size: 18px; font-weight: 500; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--line); }
+.doc .totals .row .v { font-variant-numeric: tabular-nums; }
+
+/* Worker (mobile) */
+.mw {
+  background: var(--paper);
+  min-height: 100%;
+  display: flex; flex-direction: column;
+  padding-top: 8px;
+}
+.mw .mw-top {
+  padding: 12px 20px 8px;
+  display: flex; align-items: center; justify-content: space-between;
+}
+.mw .mw-top .hello { font-size: 13px; color: var(--muted); }
+.mw .mw-top .hello b { color: var(--ink); font-weight: 500; }
+.mw .clock-card {
+  margin: 8px 16px 0;
+  background: var(--ink);
+  color: #FAFAF7;
+  border-radius: 18px;
+  padding: 18px 18px 16px;
+  position: relative;
+  overflow: hidden;
+}
+.mw .clock-card::after {
+  content: "";
+  position: absolute; right: -40px; top: -40px;
+  width: 140px; height: 140px;
+  background: radial-gradient(circle, rgba(243,147,20,0.22), transparent 70%);
+  pointer-events: none;
+}
+.mw .clock-card .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
+.mw .clock-card .time { font-family: var(--mono); font-size: 38px; font-weight: 500; margin-top: 6px; font-feature-settings: "tnum"; letter-spacing: -0.02em; }
+.mw .clock-card .for { font-size: 12.5px; color: rgba(255,255,255,0.65); margin-top: 2px; }
+.mw .clock-card .for b { color: #fff; font-weight: 500; }
+.mw .clock-card .ctrls { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px; position: relative; }
+.mw .clock-card .ctrls .b {
+  height: 44px;
+  border-radius: 10px;
+  display: flex; align-items: center; justify-content: center; gap: 6px;
+  font-size: 13px; font-weight: 500;
+  border: 1px solid rgba(255,255,255,0.12);
+  background: rgba(255,255,255,0.06);
+  color: #fff;
+  cursor: pointer;
+  font-family: inherit;
+}
+.mw .clock-card .ctrls .b.go { background: var(--orange); color: #1A1208; border-color: var(--orange); font-weight: 600; }
+.mw .clock-card .ctrls .b:disabled { opacity: .5; cursor: not-allowed; }
+.mw .section-h { padding: 18px 20px 6px; display: flex; align-items: center; justify-content: space-between; }
+.mw .section-h .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.mw .section-h .a { font-size: 12px; color: var(--ink-2); text-decoration: none; }
+.mw .jobs { padding: 0 16px; display: flex; flex-direction: column; gap: 8px; }
+.mw .jc {
+  background: #FFFFFF;
+  border: 1px solid var(--line);
+  border-radius: 14px;
+  padding: 14px 14px;
+  text-decoration: none;
+  color: inherit;
+  display: block;
+}
+.mw .jc .t  { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
+.mw .jc .ti { font-size: 14px; font-weight: 500; color: var(--ink); }
+.mw .jc .ad { font-size: 12.5px; color: var(--muted); margin-top: 2px; }
+.mw .jc .row { display: flex; align-items: center; gap: 12px; margin-top: 10px; font-size: 12px; color: var(--ink-2); }
+.mw .jc .row span { display: inline-flex; align-items: center; gap: 5px; }
+.tabbar {
+  display: grid; grid-template-columns: repeat(4, 1fr);
+  border-top: 1px solid var(--line);
+  background: #FFFFFF;
+  padding: 8px 4px 18px;
+}
+.tabbar .ti {
+  display: flex; flex-direction: column; align-items: center; gap: 3px;
+  font-size: 10.5px; color: var(--muted);
+  text-decoration: none;
+  padding: 6px 0;
+  min-height: 44px;
+}
+.tabbar .ti.is-active { color: var(--ink); }
+.tabbar .ti.is-active svg { color: var(--orange); }
+
+/* Worker job detail */
+.mw .jh {
+  padding: 12px 20px 8px;
+  display: flex; flex-direction: column; gap: 6px;
+}
+.mw .jh .ti { font-size: 19px; font-weight: 500; letter-spacing: -0.01em; }
+.mw .jh .ad { font-size: 12.5px; color: var(--muted); }
+.mw .jh .row { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
+.mw .ckl { padding: 4px 16px 16px; }
+.mw .ckl .h { padding: 10px 4px 6px; display: flex; justify-content: space-between; align-items: center; }
+.mw .ckl .h .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.mw .ckl .h .p { font-family: var(--mono); font-size: 11.5px; color: var(--ink-2); font-variant-numeric: tabular-nums; }
+.mw .ckl .item {
+  display: flex; align-items: center; gap: 12px;
+  padding: 12px 12px; background: #FFFFFF;
+  border: 1px solid var(--line);
+  border-radius: 12px; margin-bottom: 6px;
+}
+.mw .ckl .item .cb {
+  width: 22px; height: 22px; border-radius: 6px;
+  border: 1.5px solid var(--line-strong);
+  flex: none;
+  background: transparent;
+  cursor: pointer;
+}
+.mw .ckl .item.is-done .cb {
+  background: var(--ink); border-color: var(--ink);
+  position: relative;
+}
+.mw .ckl .item.is-done .cb::after {
+  content: ""; position: absolute; inset: 0;
+  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='none' stroke='%23F39314' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><path d='M3.5 8.5l3 3 6-6'/></svg>");
+  background-size: 14px; background-position: center; background-repeat: no-repeat;
+}
+.mw .ckl .item.is-done .lbl { color: var(--muted); text-decoration: line-through; text-decoration-color: var(--muted-3); }
+.mw .ckl .item .lbl { font-size: 13.5px; }
+.mw .ckl .item .ph { margin-left: auto; font-family: var(--mono); font-size: 10.5px; color: var(--muted); }
+
+/* Worker mobile stat cards */
+.mw .stat-card {
+  background: #FFFFFF; border: 1px solid var(--line); border-radius: 12px;
+  padding: 12px 14px;
+}
+.mw .stat-card .k { font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
+.mw .stat-card .v { font-family: var(--mono); font-size: 22px; font-weight: 500; margin-top: 4px; letter-spacing: -0.01em; }
+
+/* Portal */
+.portal { background: var(--paper); min-height: 100%; }
+.portal .ptop {
+  display: flex; justify-content: space-between; align-items: center;
+  padding: 14px 36px;
+  border-bottom: 1px solid var(--line);
+  background: #FFFFFF;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+.portal .ptop .brand { display: flex; gap: 10px; align-items: center; }
+.portal .ptop .brand-mark {
+  width: 28px; height: 28px;
+  background: var(--orange); border-radius: 7px;
+  display: grid; place-items: center; overflow: hidden;
+  flex: none;
+}
+.portal .ptop .brand-mark img { width: 100%; height: 100%; object-fit: contain; }
+.portal .ptop .name { font-weight: 600; letter-spacing: 0.02em; font-size: 14px; }
