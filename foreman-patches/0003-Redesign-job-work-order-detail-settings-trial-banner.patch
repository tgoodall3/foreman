+const AVATAR_TONES = ["avatar--orange", "avatar--blue", "avatar--green"];
+
+function jobStatusPill(status: string) {
+  switch (status) {
+    case "in_progress": return { cls: "pill--inprog",    label: "In progress" };
+    case "completed":   return { cls: "pill--done",      label: "Completed" };
+    case "invoiced":    return { cls: "pill--paid",      label: "Invoiced" };
+    case "cancelled":   return { cls: "pill--draft",     label: "Cancelled" };
+    case "pending":     return { cls: "pill--unassigned",label: "Pending" };
+    default:            return { cls: "pill--scheduled", label: "Scheduled" };
+  }
+}
+
+function priorityPill(p?: string | null) {
+  switch (p) {
+    case "emergency":
+    case "urgent":   return { cls: "pill--high", label: p === "emergency" ? "Emergency" : "Urgent" };
+    case "high":     return { cls: "pill--high", label: "High" };
+    case "normal":   return { cls: "pill--med",  label: "Normal" };
+    case "low":      return { cls: "pill--low",  label: "Low" };
+    default:         return null;
+  }
+}
+
+function changeOrderPill(status: string) {
+  switch (status) {
+    case "approved": return { cls: "pill--done", label: "Approved" };
+    case "declined": return { cls: "pill--late", label: "Declined" };
+    case "sent":     return { cls: "pill--sent", label: "Sent" };
+    case "draft":    return { cls: "pill--draft", label: "Draft" };
+    default:         return { cls: "pill--draft", label: status };
+  }
+}
+
+function initials(name: string) {
+  return name.trim().split(/\s+/).map((w) => w[0]).slice(0, 2).join("").toUpperCase() || "—";
+}
